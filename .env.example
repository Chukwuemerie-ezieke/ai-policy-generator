# AI Governance Policy Generator — Environment Variables
# Copy this file to .env and fill in values as needed.
# For local development, most of these are optional — the app runs with SQLite by default.

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────

# Port the Express server listens on (default: 5000)
PORT=5000

# Node environment: "development" | "production"
NODE_ENV=development

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

# Path to the SQLite database file (relative to project root)
# In production, use an absolute path or mount a persistent volume.
DATABASE_PATH=./db.sqlite

# ─────────────────────────────────────────────
# OPTIONAL — EMAIL DELIVERY (future feature)
# ─────────────────────────────────────────────

# Zoho Mail SMTP credentials (for emailing generated policies)
# ZOHO_MAIL_HOST=smtp.zoho.com
# ZOHO_MAIL_PORT=587
# ZOHO_MAIL_USER=noreply@harmonydigitalconsults.com
# ZOHO_MAIL_PASS=your_zoho_app_password

# ─────────────────────────────────────────────
# OPTIONAL — ANALYTICS (future feature)
# ─────────────────────────────────────────────

# PostHog analytics (for usage tracking)
# VITE_POSTHOG_KEY=your_posthog_project_api_key
# VITE_POSTHOG_HOST=https://app.posthog.com
